# ============================================================================
# Kaizen Dashboard — Environment Variables
# ============================================================================
# Copy this file to .env and fill in values as needed.
# All variables are OPTIONAL — the app runs without them (SSO disabled).
# ============================================================================

# ── Microsoft Entra ID SSO (set ALL four to enable SSO) ─────────────────────
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=https://your-app.onrender.com/auth/callback

# ── Session signing key (random string, keep secret) ────────────────────────
SESSION_SECRET_KEY=

# ── Optional: restrict email domains (comma-separated) ──────────────────────
ALLOWED_EMAIL_DOMAINS=eon.com,delgaz-grid.ro

# ── Optional: restrict Azure AD tenant IDs (comma-separated) ────────────────
ALLOWED_TENANT_IDS=
